# ⚠️  Dit bestand wordt naar GitHub gepusht. NOOIT echte API-keys hier zetten.
# Echte keys horen in .env.local (gitignored) of Vercel env vars.

# Turso database
# Voor lokaal: TURSO_DATABASE_URL=file:./local.db (geen auth token nodig)
# Voor productie: gebruik je Turso cloud URL
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# JWT secret — generate met: openssl rand -base64 32
AUTH_SECRET=

# Football-data.org API key (gratis op https://www.football-data.org/client/register)
# Optioneel — zonder deze key werkt alles, maar je moet uitslagen handmatig invoeren via /admin/wedstrijden
FOOTBALL_DATA_API_KEY=

# Random secret voor cron-endpoint (auth header: Bearer <CRON_SECRET>)
# Genereer met: openssl rand -hex 32
# Vercel cron stuurt dit automatisch mee; externe cron (cron-job.org) configureer je handmatig.
CRON_SECRET=

# Optioneel: Gemini API key voor AI-voorspelling (Gemini 2.5 Flash)
# Maak gratis aan op https://aistudio.google.com/apikey — alleen nodig voor de verborgen auto-fill knop
GEMINI_API_KEY=
# E-mail van de gebruiker die de verborgen AI-knop in /admin ziet (lowercase)
AI_PREDICT_EMAIL=
